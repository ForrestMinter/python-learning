   "source": [
    "# 幸运数字\n",
    "import random\n",
    "name = input(\"请输入名字：\")\n",
    "lucky = 1\n",
    "random.seed(7)\n",
    "for c in name:\n",
    "    lucky += ord(c) * random.randint(1,77)\n",
    "print(\"幸运数字是：{}\".format(lucky % 777))"
   ]
  }
