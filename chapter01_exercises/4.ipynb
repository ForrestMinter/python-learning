    "# 阶乘序列求和 1! + 2! + 3! + ... + 10!\n",
    "sum = 0\n",
    "tmp = 1\n",
    "for i in range(1,11):\n",
    "    tmp *= i      # 计算 i!\n",
    "    sum += tmp    # 累加\n",
    "print(\"运算结果是:{}\".format(sum))"
   ]
  }
