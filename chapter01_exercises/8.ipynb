   "source": [
    "# 太阳花绘制\n",
    "import turtle\n",
    "\n",
    "t = turtle.Turtle()\n",
    "t.color(\"red\", \"yellow\")\n",
    "t.speed(10)\n",
    "\n",
    "t.begin_fill()\n",
    "for i in range(36):\n",
    "    t.forward(200)\n",
    "    t.left(170)\n",
    "t.end_fill()\n",
    "\n",
    "turtle.done()"
   ]
  }
 ],
