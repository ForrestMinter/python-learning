   "source": [
    "# 五角星绘制\n",
    "import turtle\n",
    "\n",
    "t = turtle.Turtle()\n",
    "t.color(\"red\")\n",
    "t.pensize(2)\n",
    "\n",
    "for i in range(5):\n",
    "    t.forward(100)\n",
    "    t.right(144)  # 五角星的角度\n",
    "\n",
    "turtle.done()  # 保持窗口"
   ]
  }
 ],
